# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/lib/generated/prisma
prisma/*.db
prisma/*.db-journal

# Local user-uploaded files (avatars etc.) — environment-specific, not
# committed. The empty directory stub at /public/uploads/.gitkeep keeps the
# folder around so the LocalStorageAdapter can write into it on first run.
/public/uploads/*
!/public/uploads/.gitkeep

