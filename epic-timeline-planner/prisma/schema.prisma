generator client {
  provider = "prisma-client-js"
  /** App-local output so the dev server never picks up SDLC/node_modules/.prisma (legacy schema). */
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum InitiativeStatus {
  backlog
  scheduled
}

enum StoryStatus {
  todo
  inProgress
  review
  done
}

model Roadmap {
  id          String      @id @default(uuid())
  name        String
  /** Sorted list of calendar years in scope for this roadmap. */
  years       String      @default("[]")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  initiatives Initiative[]
}

model Initiative {
  id          String              @id @default(uuid())
  title       String
  icon        String              @default("")
  description String?
  assignee    String?
  color       String              @default("#3B82F6")
  status      InitiativeStatus    @default(backlog)
  startMonth  Int?
  endMonth    Int?
  /** Inclusive global year sprint 1–24 (two per month); null when unscheduled. Finer bounds than months on full-year Gantt. */
  startYearSprint Int?
  endYearSprint   Int?
  /** Vertical order in full-roadmap Gantt (lower = higher on screen). Preserved when moving months. */
  timelineRow Int              @default(0)
  year        Int
  roadmapId   String?
  roadmap     Roadmap?            @relation(fields: [roadmapId], references: [id])
  /** Delivery team id surfaced for the initiative; mirrors epic.team. */
  team        String?
  /** Free-form labels (comma-separated). */
  labels      String?
  epics       Epic[]
  comments    InitiativeComment[]
  history     InitiativeHistory[]
  /** Self-relation: when set, this initiative is a year-end continuation of
   *  `parentInitiative` from the prior year. Preserves the link between
   *  the original (frozen as history) and the new replan. */
  parentInitiativeId String?
  parentInitiative   Initiative?  @relation("InitiativeContinuation", fields: [parentInitiativeId], references: [id], onDelete: SetNull)
  continuations      Initiative[] @relation("InitiativeContinuation")
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model InitiativeComment {
  id           String     @id @default(uuid())
  body         String
  author       String?
  initiativeId String
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
}

model InitiativeHistory {
  id           String     @id @default(uuid())
  entry        String
  /** Display name of the signed-in user who triggered the change. Nullable
   *  because pre-existing entries pre-date this column, and because system
   *  / automation events have no human author. UI shows "System" when null. */
  userName     String?
  initiativeId String
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
}

model Epic {
  id           String        @id @default(uuid())
  title        String
  icon         String        @default("📁")
  description  String?
  assignee     String?
  originalEstimateDays Int?
  color        String        @default("#3B82F6")
  initiativeId String
  roadmapId    String?
  planYear       Int?
  planQuarter    Int?
  initiative     Initiative    @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  planSprint     Int?
  planStartMonth Int?
  planEndMonth   Int?
  planEndSprint  Int?          @default(2)
  /** Day-of-month (1–31) for start/end within the plan month; null = use sprint halves. */
  planStartDay   Int?
  planEndDay     Int?
  /** Vertical order in roadmap Gantt for epic bars (lower = higher on screen). */
  timelineRow    Int           @default(0)
  /** Order in initiative backlog / epic list (lower = higher). */
  backlogOrder   Int           @default(0)
  /** Delivery team id when assigned on the month team board (`platform` | `experience` | `data`). */
  team           String?
  /** Free-form labels (comma-separated). */
  labels         String?
  /** Optional priority (P0..P3). */
  priority       String?
  userStories    UserStory[]
  comments       EpicComment[]
  history        EpicHistory[]
  /** Self-relation mirroring {@link Initiative.parentInitiativeId}: marks
   *  this epic as a year-end continuation of its parent. Unscheduled at
   *  creation (no plan dates) until the planner opens the date popover. */
  parentEpicId   String?
  parentEpic     Epic?         @relation("EpicContinuation", fields: [parentEpicId], references: [id], onDelete: SetNull)
  continuations  Epic[]        @relation("EpicContinuation")
  /** Phase C: per-day snapshot of editable epic fields so closed-period
   *  views render frozen at close-day state. */
  epicSnapshots  EpicDailySnapshot[]
  /** Phase D: soft-delete timestamp. NULL = active row, non-null = row was
   *  deleted at this instant. Live views filter for NULL; closed-period
   *  views ignore the filter so historical kanban / capacity / charts still
   *  render the card from its snapshots. Hard delete only happens during
   *  developer reset (resetAndSeedDemo). */
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([deletedAt])
}

model EpicComment {
  id        String   @id @default(uuid())
  body      String
  author    String?
  epicId    String
  epic      Epic     @relation(fields: [epicId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model EpicHistory {
  id        String   @id @default(uuid())
  entry     String
  /** Display name of the signed-in user who triggered the change. Nullable
   *  for the same reasons as InitiativeHistory.userName. */
  userName  String?
  epicId    String
  epic      Epic     @relation(fields: [epicId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model UserStory {
  id            String         @id @default(uuid())
  title         String
  icon          String         @default("📄")
  description   String?
  assignee      String?
  /** Delivery team override — when NULL the story inherits the parent
   *  `epic.team` for display + aggregation. When set, it takes precedence
   *  over the epic's team. Lets a planner pull a single story onto a
   *  cross-team handoff without splitting the epic. */
  team          String?
  labels        String?
  priority      String?
  roadmapId     String?
  planYear      Int?
  planQuarter   Int?
  sprint        Int?
  estimatedDays Int?
  daysLeft      Int?
  status        StoryStatus    @default(todo)
  /** Order within a sprint Kanban column (lower = higher). Scoped per status column on the board. */
  backlogOrder  Int            @default(0)
  epicId        String
  epic          Epic           @relation(fields: [epicId], references: [id], onDelete: Cascade)
  comments      StoryComment[]
  history       StoryHistory[]
  snapshots     StoryDailySnapshot[]
  /** Phase D: soft-delete timestamp. NULL = active row, non-null = row was
   *  deleted at this instant. Live views filter for NULL; closed-period
   *  views ignore the filter so historical kanban renders the card from its
   *  snapshots. */
  deletedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([deletedAt])
}

model StoryComment {
  id        String    @id @default(uuid())
  body      String
  author    String?
  storyId   String
  story     UserStory @relation(fields: [storyId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
}

model StoryHistory {
  id        String    @id @default(uuid())
  entry     String
  /** Display name of the signed-in user who triggered the change. Nullable
   *  for the same reasons as InitiativeHistory.userName. */
  userName  String?
  storyId   String
  story     UserStory @relation(fields: [storyId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
}

model StoryDailySnapshot {
  id           String     @id @default(uuid())
  storyId      String
  story        UserStory  @relation(fields: [storyId], references: [id], onDelete: Cascade)
  snapshotDate DateTime
  status       StoryStatus
  sprint       Int?
  estimatedDays Int?
  daysLeft     Int?
  assignee     String?
  /** Phase B: text fields captured so closed-period views stay frozen
   *  against later renames / description edits / priority + labels changes.
   *  All nullable so pre-migration rows remain valid; projection helper
   *  falls back to the live story field when a column is null. */
  title        String?
  description  String?
  priority     String?
  labels       String?
  createdAt    DateTime   @default(now())

  @@unique([storyId, snapshotDate])
  @@index([snapshotDate])
}

model Dashboard {
  id        String           @id @default(uuid())
  slug      String           @unique @default("")
  name      String
  charts    DashboardChart[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model DashboardChart {
  id          String    @id @default(uuid())
  dashboardId String
  dashboard   Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  chartType   String
  title       String
  config      String
  position    Int       @default(0)
  colSpan     Int       @default(1)
  rowSpan     Int       @default(1)
  createdAt   DateTime  @default(now())
}

/** Directory users for the Users workspace (not auth accounts). */
model WorkspaceUser {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  /** Delivery trio ids, custom slug (directory-only teams), or empty when unassigned. */
  team       String   @default("")
  /** Display name for role, e.g. Admin, Editor, Viewer. */
  permission String   @default("Viewer")
  /** Directory lifecycle; not editable in UI (currently all `active`). */
  status     String   @default("active")
  /**
   * Avatar URL — currently a local path like `/uploads/avatars/<uuid>.<ext>`
   * served by Next.js from `public/`. The storage backend is hidden behind
   * `lib/storage` so this can later point at S3 / R2 / etc. with no schema
   * change; the column is just an opaque URL string.
   */
  image      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  /** Back-link from the auth User; set when a User signs up with this email. */
  user User?
  /** Teams this user leads. Members of a team are derived by filtering
   *  WorkspaceUser by `team === Team.slug` — there is no separate members
   *  table, so the slug is the single source of truth for membership. */
  ledTeams Team[] @relation("TeamLead")

  @@index([team])
  @@index([permission])
  @@index([status])
}

/**
 * First-class team entity for the directory.
 *
 * `slug` is the identifier referenced elsewhere as a plain string (e.g.
 * `WorkspaceUser.team`, `Epic.team`, `Initiative.team`). Membership is
 * therefore implicit: a user is a member of a team when their `team`
 * equals this team's `slug`. The leader is an explicit FK to
 * `WorkspaceUser`; clearing that user clears the lead (`SetNull`).
 *
 * Image URLs follow the same opaque-URL contract as `WorkspaceUser.image`
 * — stored as `/uploads/team-images/<uuid>.<ext>` today via the storage
 * adapter, swappable to S3 / R2 / etc. without schema changes.
 */
model Team {
  id           String         @id @default(uuid())
  /** Kebab-case identifier referenced by `WorkspaceUser.team` etc. */
  slug         String         @unique
  /** Human-readable display name for chips, pickers, headers. */
  displayName  String
  description  String?
  image        String?
  leadId       String?
  lead         WorkspaceUser? @relation("TeamLead", fields: [leadId], references: [id], onDelete: SetNull)
  /** Manual sort order in pickers / sidebars (lower = higher). */
  displayOrder Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([displayOrder])
}

// ──────────────────────────────────────────────────────────────────────────────
// Auth models (Better Auth shape) — separate from WorkspaceUser. The auth User
// is the login identity; WorkspaceUser is the team-directory profile. On first
// signup we soft-link them by email so directory entries an admin added in
// advance "activate" when that person signs up. See lib/auth.ts.
// ──────────────────────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  emailVerified    Boolean   @default(false)
  name             String?
  image            String?
  /** Null for OAuth-only users; bcrypt hash for credentials users. */
  passwordHash     String?
  /** Consecutive failed-login count for this email. Reset on success. */
  failedLoginCount Int       @default(0)
  /** Brute-force lockout window end; UI shows a "try again in X minutes" message until this passes. */
  lockedUntil      DateTime?
  workspaceUserId  String?   @unique
  workspaceUser    WorkspaceUser? @relation(fields: [workspaceUserId], references: [id])
  accounts         Account[]
  sessions         Session[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([email])
}

model Account {
  id                    String    @id @default(uuid())
  userId                String
  /** "credentials" | "google" | "apple" | "microsoft" */
  providerId            String
  /** OAuth `sub` or, for credentials, the email. */
  accountId             String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  /** Better Auth may also store credentials hash here; we keep it on User.passwordHash instead. */
  password              String?
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  /** Random opaque token stored in the session cookie. */
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model Verification {
  id         String   @id @default(uuid())
  /** Subject of the verification: email address for password-reset / email-verify flows. */
  identifier String
  /** The hashed token / code. */
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model RateLimitEvent {
  id        String   @id @default(uuid())
  /** Sliding-window key, e.g. `login:email:foo@bar.com` or `signup:ip:1.2.3.4`. */
  key       String
  createdAt DateTime @default(now())

  @@index([key, createdAt])
}

/**
 * Phase C: per-day snapshot of editable epic fields. Mirrors
 * {@link StoryDailySnapshot} — captured idempotently on every epic
 * mutation (via {@link captureEpicDailySnapshot}) and once per day during
 * demo refresh. Read by closed-period views (closed sprint kanban /
 * capacity, past month / quarter capacity, year insights) so renaming an
 * epic / changing its estimate / swapping its team in the present doesn't
 * bleed back into history. All editable fields nullable so pre-migration
 * rows remain valid; the projection helper falls back to live `epic.field`
 * when a column is null.
 */
model EpicDailySnapshot {
  id                   String   @id @default(uuid())
  epicId               String
  epic                 Epic     @relation(fields: [epicId], references: [id], onDelete: Cascade)
  snapshotDate         DateTime
  title                String?
  description          String?
  icon                 String?
  color                String?
  originalEstimateDays Int?
  priority             String?
  labels               String?
  team                 String?
  planStartMonth       Int?
  planEndMonth         Int?
  planSprint           Int?
  planEndSprint        Int?
  planStartDay         Int?
  planEndDay           Int?
  createdAt            DateTime @default(now())

  @@unique([epicId, snapshotDate])
  @@index([snapshotDate])
}
